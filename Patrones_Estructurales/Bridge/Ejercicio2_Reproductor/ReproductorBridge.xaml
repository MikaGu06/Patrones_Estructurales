<UserControl x:Class="Patrones_Estructurales.Bridge.Ejercicio2_Reproductor.ReproductorBridge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Patrones_Estructurales.Bridge.Ejercicio2_Reproductor">

    <UserControl.Resources>
        <!-- Estilo para botones circulares -->
        <Style x:Key="CircularButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para botones pequeños -->
        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="17.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel>
            <!-- Título -->
            <Border Background="{Binding Reproductor.ColorFondoPrincipal}"
                    Padding="20"
                    CornerRadius="12"
                    Margin="15">
                <TextBlock Text="Reproductor de Musica - Patron Bridge"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{Binding Reproductor.ColorTexto}"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Selector de temas -->
            <Border Background="{Binding Reproductor.ColorFondoSecundario}"
                    BorderBrush="{Binding Reproductor.ColorBorde}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="20"
                    Margin="15">

                <StackPanel>
                    <TextBlock Text="CAMBIAR TEMA VISUAL (Bridge en accion)"
                               Foreground="{Binding Reproductor.ColorTexto}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,15"
                               HorizontalAlignment="Center"/>

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Background="#E0E0E8"
                                Foreground="#1E1E2E"
                                FontWeight="Bold"
                                FontSize="14"
                                Padding="25,12"
                                Margin="8"
                                Cursor="Hand"
                                Click="BtnTemaClaro_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="TEMA CLARO" />
                        </Button>

                        <Button Background="#2A2A3A"
                                Foreground="#E8E8F0"
                                FontWeight="Bold"
                                FontSize="14"
                                Padding="25,12"
                                Margin="8"
                                Cursor="Hand"
                                Click="BtnTemaOscuro_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="TEMA OSCURO" />
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Reproductor principal -->
            <Border Background="{Binding Reproductor.ColorFondoSecundario}"
                    BorderBrush="{Binding Reproductor.ColorBorde}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="25"
                    Margin="15">

                <StackPanel>
                    <!-- Información de la canción -->
                    <TextBlock Text="{Binding Reproductor.CancionActual}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{Binding Reproductor.ColorTexto}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="{Binding Reproductor.EstadoTexto}"
                               FontSize="12"
                               Foreground="{Binding Reproductor.ColorTextoSubtitulo}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Barra de progreso -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="0:00"
                                   Foreground="{Binding Reproductor.ColorTextoSubtitulo}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>

                        <Slider Grid.Column="1"
                                Value="{Binding Reproductor.Progreso, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="1"
                                Margin="10,0"
                                Foreground="{Binding Reproductor.ColorProgreso}"/>

                        <TextBlock Grid.Column="2"
                                   Text="3:30"
                                   Foreground="{Binding Reproductor.ColorTextoSubtitulo}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Controles de reproducción -->
                    <WrapPanel HorizontalAlignment="Center"
                               Margin="0,10,0,10">

                        <Button Style="{StaticResource SmallButtonStyle}"
                                Background="{Binding Reproductor.ColorBoton}"
                                Foreground="{Binding Reproductor.ColorTexto}"
                                Content="⏮"
                                Click="BtnAnterior_Click"
                                Margin="5"/>

                        <Button Style="{StaticResource CircularButtonStyle}"
                                Background="{Binding Reproductor.ColorProgreso}"
                                Foreground="White"
                                Content="{Binding Reproductor.EstadoIcono}"
                                Click="BtnPlayPause_Click"
                                Margin="10,0"/>

                        <Button Style="{StaticResource SmallButtonStyle}"
                                Background="{Binding Reproductor.ColorBoton}"
                                Foreground="{Binding Reproductor.ColorTexto}"
                                Content="⏭"
                                Click="BtnSiguiente_Click"
                                Margin="5"/>
                    </WrapPanel>

                    <!-- Control de volumen -->
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="30"
                                Height="30"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="{Binding Reproductor.ColorBoton}"
                                Foreground="{Binding Reproductor.ColorTexto}"
                                Content="−"
                                Click="BtnBajarVolumen_Click"
                                Margin="0,0,5,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="15"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Slider Grid.Column="1"
                                Value="{Binding Reproductor.Volumen, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="1"
                                Margin="5,0"/>

                        <Button Grid.Column="2"
                                Width="30"
                                Height="30"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="{Binding Reproductor.ColorBoton}"
                                Foreground="{Binding Reproductor.ColorTexto}"
                                Content="+"
                                Click="BtnSubirVolumen_Click"
                                Margin="5,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="15"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <TextBlock Text="{Binding Reproductor.VolumenPorcentaje}"
                               FontSize="11"
                               Foreground="{Binding Reproductor.ColorTextoSubtitulo}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Lista de canciones -->
            <Border Background="{Binding Reproductor.ColorFondoSecundario}"
                    BorderBrush="{Binding Reproductor.ColorBorde}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="15"
                    Margin="15">

                <StackPanel>
                    <TextBlock Text="LISTA DE REPRODUCCION"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{Binding Reproductor.ColorTexto}"
                               Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding Reproductor.ListaCanciones}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,5"
                                        Margin="0,2"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="CancionSeleccionada">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="CornerRadius" Value="5"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{Binding DataContext.Reproductor.ColorBoton, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{Binding DataContext.Reproductor.ColorTexto, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Explicación del patrón -->
            <Border Background="{Binding Reproductor.ColorFondoSecundario}"
                    BorderBrush="{Binding Reproductor.ColorBorde}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="15"
                    Margin="15,0,15,15">

                <TextBlock Foreground="{Binding Reproductor.ColorTextoSubtitulo}"
                           FontSize="11"
                           TextAlignment="Center"
                           TextWrapping="Wrap">
                        🔗 Patron Bridge: El reproductor NO sabe que colores tiene.
                        Los temas (claro/oscuro) son intercambiables en tiempo real.
                        Haz clic en los botones de tema y mira como cambian todos los colores!
                </TextBlock>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>