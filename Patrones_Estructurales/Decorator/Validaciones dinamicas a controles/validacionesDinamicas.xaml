<UserControl x:Class="Patrones_Estructurales.Decorator.Validaciones.Validaciones"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}" Background="{StaticResource Card}">
        <StackPanel>
            <TextBlock Text="Validaciones dinámicas a controles"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextoOscuro}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Ingrese un valor:"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtValor"
                     Height="35"
                     Padding="8"
                     Margin="0,5,0,15"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <CheckBox x:Name="ChkVacio"
                      Content="Validar que no esté vacío"
                      IsChecked="True"
                      Margin="0,5"/>

            <CheckBox x:Name="ChkNumerico"
                      Content="Validar que solo acepte números"
                      Margin="0,5"/>

            <CheckBox x:Name="ChkLongitud"
                      Content="Validar longitud mínima"
                      Margin="0,5"/>

            <TextBlock Text="Longitud mínima:"
                       Margin="0,10,0,5"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtLongitud"
                     Text="5"
                     Height="35"
                     Padding="8"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <Button Content="Validar"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="0,15,0,15"
                    Click="BtnValidar_Click"/>

            <TextBlock x:Name="TxtResultado"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ColorPrimario}"/>
        </StackPanel>
    </Border>
</UserControl>