<UserControl x:Class="Patrones_Estructurales.Decorator.ComportamientoAdicional.ComportamientoAdicional"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}" Background="{StaticResource Card}">
        <StackPanel>
            <TextBlock Text="Aplicar comportamiento adicional sin modificar la clase base"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextoOscuro}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Nombre del producto:"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtProducto"
                     Height="35"
                     Padding="8"
                     Margin="0,5,0,10"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <TextBlock Text="Precio base:"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtPrecio"
                     Text="100"
                     Height="35"
                     Padding="8"
                     Margin="0,5,0,15"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <CheckBox x:Name="ChkImpuesto"
                      Content="Aplicar impuesto"
                      IsChecked="True"
                      Margin="0,5"/>

            <TextBlock Text="Impuesto (%):"
                       Margin="0,5,0,5"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtImpuesto"
                     Text="13"
                     Height="35"
                     Padding="8"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <CheckBox x:Name="ChkDescuento"
                      Content="Aplicar descuento"
                      IsChecked="True"
                      Margin="0,15,0,5"/>

            <TextBlock Text="Descuento (Bs):"
                       Margin="0,5,0,5"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtDescuento"
                     Text="10"
                     Height="35"
                     Padding="8"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <Button Content="Calcular precio decorado"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="0,15,0,15"
                    Click="BtnCalcular_Click"/>

            <TextBlock x:Name="TxtResultado"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ColorPrimario}"/>
        </StackPanel>
    </Border>
</UserControl>