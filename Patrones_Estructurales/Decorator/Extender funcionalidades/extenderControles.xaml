<UserControl x:Class="Patrones_Estructurales.Decorator.ExtenderControles.ExtenderControles"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}" Background="{StaticResource Card}">
        <StackPanel>
            <TextBlock Text="Extender funcionalidades de botones o TextBox"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextoOscuro}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Texto a procesar:"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtTexto"
                     Height="35"
                     Padding="8"
                     Margin="0,5,0,15"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <CheckBox x:Name="ChkRegistro"
                      Content="Agregar registro de acción"
                      Margin="0,5"/>

            <CheckBox x:Name="ChkMayuscula"
                      Content="Convertir a mayúsculas"
                      Margin="0,5"/>

            <CheckBox x:Name="ChkFecha"
                      Content="Agregar fecha y hora"
                      Margin="0,5"/>

            <Button Content="Ejecutar acción"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="0,15,0,15"
                    Click="BtnEjecutar_Click"/>

            <TextBlock x:Name="TxtResultado"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ColorPrimario}"/>
        </StackPanel>
    </Border>
</UserControl>