<UserControl x:Class="Patrones_Estructurales.Facade.Facade"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,15">
            <Button Content="Acceso a servicios"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5"
                    Click="BtnAcceso_Click"/>

            <Button Content="Múltiples servicios"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5"
                    Click="BtnMultiples_Click"/>

            <Button Content="Gestor central"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5"
                    Click="BtnGestor_Click"/>
        </UniformGrid>

        <Border Grid.Row="1"
                CornerRadius="8"
                Padding="15">

            <ContentControl x:Name="ContenedorFacade"/>

        </Border>
    </Grid>
</UserControl>