<UserControl x:Class="Patrones_Estructurales.Facade.GestorCentral.GestorCentral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}" Background="{StaticResource Card}">
        <StackPanel>
            <TextBlock Text="Crear un gestor central de operaciones del sistema"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextoOscuro}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="El Facade actúa como gestor central y permite ejecutar operaciones del sistema desde una sola clase."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextoClaro}"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Nombre del operador:"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="TxtOperador"
                     Height="35"
                     Padding="8"
                     Margin="0,5,0,15"
                     Background="{StaticResource InputColor}"
                     BorderBrush="{StaticResource BordesSuaves}"/>

            <CheckBox x:Name="ChkBackup"
                      Content="Realizar backup"
                      IsChecked="True"
                      Margin="0,5"/>

            <CheckBox x:Name="ChkReporte"
                      Content="Generar reporte"
                      IsChecked="True"
                      Margin="0,5"/>

            <CheckBox x:Name="ChkNotificacion"
                      Content="Enviar notificación"
                      IsChecked="True"
                      Margin="0,5"/>

            <Button Content="Ejecutar gestor central"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="0,15,0,15"
                    Click="BtnEjecutar_Click"/>

            <TextBlock x:Name="TxtResultado"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ColorPrimario}"/>
        </StackPanel>
    </Border>
</UserControl>