<UserControl x:Class="Patrones_Estructurales.Proxy.Ejercicio1_ControlAcceso.ControlAccesoProxy"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Patrones_Estructurales.Proxy.Ejercicio1_ControlAcceso">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Título -->
            <Border Background="{StaticResource ColorPrimario}"
                    Padding="20"
                    CornerRadius="12"
                    Margin="15">
                <TextBlock Text="Control de Acceso a Documentos - Proxy de Seguridad"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource FondoLavanda}"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Selector de usuario -->
            <Border Background="{StaticResource ColorPrimario}"
                    BorderBrush="{StaticResource PrimarioSuave}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="20"
                    Margin="15">

                <StackPanel>
                    <TextBlock Text="SELECCIONA UN USUARIO (Proxy controla acceso)"
                               Foreground="{StaticResource FondoLavanda}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,15"
                               HorizontalAlignment="Center"/>

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Background="Gold"
                                Foreground="Black"
                                FontWeight="Bold"
                                Padding="15,10"
                                Margin="5"
                                Cursor="Hand"
                                Click="BtnAdmin_Click">
                            <TextBlock Text="Admin (Todo)"/>
                        </Button>

                        <Button Background="LightBlue"
                                Foreground="Black"
                                FontWeight="Bold"
                                Padding="15,10"
                                Margin="5"
                                Cursor="Hand"
                                Click="BtnEditor_Click">
                            <TextBlock Text="Editor (Ver + Editar)"/>
                        </Button>

                        <Button Background="LightGray"
                                Foreground="Black"
                                FontWeight="Bold"
                                Padding="15,10"
                                Margin="5"
                                Cursor="Hand"
                                Click="BtnLector_Click">
                            <TextBlock Text="Lector (Solo ver)"/>
                        </Button>

                        <Button Background="DarkGray"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="15,10"
                                Margin="5"
                                Cursor="Hand"
                                Click="BtnInvitado_Click">
                            <TextBlock Text="Invitado (Sin acceso)"/>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Documento -->
            <Border Background="{StaticResource ColorPrimario}"
                    BorderBrush="{StaticResource PrimarioSuave}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="20"
                    Margin="15">

                <StackPanel>
                    <TextBlock Text="DOCUMENTO"
                               FontWeight="Bold"
                               Foreground="{StaticResource FondoLavanda}"
                               FontSize="14"
                               Margin="0,0,0,10"/>

                    <!-- Título -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Titulo:" Foreground="{StaticResource FondoLavanda}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="{Binding Titulo}" Foreground="{StaticResource FondoLavanda}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Text="Autor:" Foreground="{StaticResource FondoLavanda}" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Autor}" Foreground="{StaticResource FondoLavanda}" Margin="0,5,0,0"/>

                        <TextBlock Grid.Row="2" Text="Rol:" Foreground="{StaticResource FondoLavanda}" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RolActual}" Foreground="{StaticResource FondoLavanda}" Margin="0,5,0,0"/>
                    </Grid>

                    <!-- Contenido -->
                    <Border Background="{StaticResource ColorPrimarioHover}"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,15,0,0">
                        <TextBlock Text="{Binding Contenido}"
                                   Foreground="{StaticResource FondoLavanda}"
                                   TextWrapping="Wrap"
                                   FontSize="13"/>
                    </Border>

                    <!-- Botones de accion -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,15,0,0"
                                Visibility="{Binding DocumentoExiste, Converter={StaticResource BoolToVisibility}}">

                        <Button Background="{StaticResource ColorPrimario}"
                                Foreground="White"
                                Padding="15,8"
                                Margin="5"
                                Cursor="Hand"
                                Click="BtnEditar_Click"
                                IsEnabled="{Binding PuedeEditar}">
                            <TextBlock Text="EDITAR"/>
                        </Button>

                        <Button Background="#8A4D67"
                                Foreground="White"
                                Padding="15,8"
                                Margin="5"
                                Cursor="Hand"
                                Click="BtnEliminar_Click"
                                IsEnabled="{Binding PuedeEliminar}">
                            <TextBlock Text="ELIMINAR"/>
                        </Button>
                    </StackPanel>

                    <!-- Boton CREAR (solo cuando NO hay documento y el usuario puede crear) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,15,0,0"
                                Visibility="{Binding DocumentoExiste, Converter={StaticResource InvertBoolToVisibility}}">

                        <Button Background="#4CAF50"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="20,12"
                                Margin="5"
                                Cursor="Hand"
                                Click="BtnCrear_Click"
                                IsEnabled="{Binding PuedeCrear}">
                            <TextBlock Text="CREAR NUEVO DOCUMENTO"/>
                        </Button>
                    </StackPanel>

                    <!-- Mensaje sin acceso al documento existente -->
                    <Border Background="#8A4D67"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,15,0,0"
                            Visibility="{Binding TieneAcceso, Converter={StaticResource InvertBoolToVisibility}}">
                        <TextBlock Text="NO TIENES ACCESO A ESTE DOCUMENTO"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Explicacion -->
            <Border Background="{StaticResource ColorPrimario}"
                    BorderBrush="{StaticResource PrimarioSuave}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="15"
                    Margin="15,0,15,15">

                <TextBlock Foreground="{StaticResource FondoLavanda}"
                           FontSize="11"
                           TextAlignment="Center"
                           TextWrapping="Wrap">
                        Patron Proxy: El usuario NUNCA accede directamente al documento.
                        El Proxy verifica permisos antes de permitir EDICION, ELIMINACION o CREACION.
                        Admin puede TODO (incluyendo CREAR) | Editor puede editar | Lector solo ver | Invitado nada
                </TextBlock>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>