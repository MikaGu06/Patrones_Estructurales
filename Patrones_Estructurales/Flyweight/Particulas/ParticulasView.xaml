<UserControl x:Class="Patrones_Estructurales.Flyweight.Particulas.ParticulasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Patrones_Estructurales.Flyweight.Particulas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Flyweight: Simulación de Partículas" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextoOscuro}"/>
            <TextBlock Text="Crea miles de partículas dinámicamente compartiendo su apariencia." Foreground="{StaticResource TextoClaro}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Color:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbColor" Width="100">
                        <ComboBoxItem Content="Rojo" IsSelected="True"/>
                        <ComboBoxItem Content="Azul"/>
                        <ComboBoxItem Content="Amarillo"/>
                        <ComboBoxItem Content="Blanco"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Tamaño:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Slider x:Name="SldTamaño" Minimum="1" Maximum="10" Value="3" Width="100"/>
                </StackPanel>

                <UniformGrid Columns="2" VerticalAlignment="Bottom">
                    <Button x:Name="BtnGenerar" Content="Generar 5,000" Style="{StaticResource MenuButtonStyle}" Margin="5,0" Width="130" Click="BtnGenerar_Click"/>
                    <Button x:Name="BtnLimpiar" Content="Reiniciar" Style="{StaticResource MenuButtonStyle}" Background="#E74C3C" Margin="5,0" Width="100" Click="BtnLimpiar_Click"/>
                </UniformGrid>

                <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock x:Name="TxtStats" Text="Partículas: 0 | Objetos Flyweight: 0" FontWeight="Bold" Foreground="{StaticResource ColorPrimario}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="Black" CornerRadius="5" ClipToBounds="True">
            <Canvas x:Name="CanvasParticulas"/>
        </Border>
    </Grid>
</UserControl>
