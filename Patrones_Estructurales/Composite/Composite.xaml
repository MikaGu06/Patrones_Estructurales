<UserControl x:Class="Patrones_Estructurales.Composite.Composite"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Patrones_Estructurales.Composite"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,15">

            <Button x:Name="BtnSistemaArchivos"
                    Content="Sistema de Archivos"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Click="BtnSistemaArchivos_Click"/>

            <Button x:Name="BtnOrganigrama"
                    Content="Organigrama Empresa"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Click="BtnOrganigrama_Click"/>

            <Button x:Name="BtnMenus"
                    Content="Menús de UI"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Click="BtnMenus_Click"/>

        </UniformGrid>

        <Border Grid.Row="1" CornerRadius="8" Padding="15">
            <ContentControl x:Name="ContenedorComposite"/>
        </Border>

    </Grid>
</UserControl>
