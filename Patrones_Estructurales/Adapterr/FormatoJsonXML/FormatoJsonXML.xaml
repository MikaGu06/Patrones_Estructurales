<UserControl x:Class="Patrones_Estructurales.Adapterr.FormatoJsonXML.FormatoJsonXML"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="5">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TÍTULO -->
            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="Adaptar formatos JSON/XML"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextoOscuro}"/>

                <TextBlock Text="El usuario agrega productos, el sistema genera XML y el Adapter lo convierte a JSON."
                           FontSize="15"
                           Foreground="{StaticResource TextoClaro}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- INPUT -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,18">

                <StackPanel>
                    <TextBlock Text="Datos del producto"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextoOscuro}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Nombre"/>
                    <TextBox x:Name="TxtNombre"
                             Height="35"
                             Padding="8"
                             Margin="0,4,0,8"/>

                    <TextBlock Text="Precio"/>
                    <TextBox x:Name="TxtPrecio"
                             Height="35"
                             Padding="8"
                             Margin="0,4,0,8"/>

                    <TextBlock Text="Stock"/>
                    <TextBox x:Name="TxtStock"
                             Height="35"
                             Padding="8"
                             Margin="0,4,0,8"/>

                    <!-- BOTONES -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">

                        <Button x:Name="BtnAgregar"
                                Content="Agregar producto"
                                Style="{StaticResource MenuButtonStyle}"
                                Width="160"
                                Margin="0,0,10,0"
                                Click="BtnAgregar_Click"/>

                        <Button x:Name="BtnConvertir"
                                Content="Generar XML y JSON"
                                Style="{StaticResource MenuButtonStyle}"
                                Width="180"
                                Click="BtnConvertir_Click"/>

                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RESULTADO -->
            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <StackPanel>

                    <TextBlock Text="Resultado"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextoOscuro}"
                               Margin="0,0,0,10"/>

                    <!-- PRODUCTOS AGREGADOS -->
                    <TextBlock Text="Productos agregados:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <Border Background="{StaticResource FondoLavanda}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">

                        <TextBlock x:Name="TxtProductosAgregados"
                                   Text="Aún no hay productos."
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- XML -->
                    <TextBlock Text="XML generado:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <Border Background="{StaticResource FondoLavanda}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">

                        <TextBlock x:Name="TxtXmlGenerado"
                                   Text="Aún no se ha generado XML."
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- JSON -->
                    <TextBlock Text="JSON adaptado:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <Border Background="{StaticResource FondoLavanda}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">

                        <TextBlock x:Name="TxtJsonResultado"
                                   Text="Aún no se ha convertido ningún dato."
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- FLUJO -->
                    <TextBlock Text="WPF → ArchivoXml → IConvertidorFormato → AdaptadorXmlJson → JSON"
                               FontFamily="Consolas"
                               FontSize="13"
                               Foreground="{StaticResource TextoClaro}"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>

</UserControl>