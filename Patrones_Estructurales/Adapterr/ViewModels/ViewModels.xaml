<UserControl x:Class="Patrones_Estructurales.Adapterr.ViewModels.ViewModels"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="Convertir datos de API a ViewModels"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextoOscuro}"/>

                <TextBlock Text="El usuario ingresa varios datos simulados de una API y el Adapter los convierte a ViewModels."
                           FontSize="15"
                           Foreground="{StaticResource TextoClaro}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,18">

                <StackPanel>
                    <TextBlock Text="Datos simulados de la API"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextoOscuro}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="full_name"/>
                    <TextBox x:Name="TxtFullName"
                             Height="35"
                             Padding="8"
                             Margin="0,4,0,8"/>

                    <TextBlock Text="email_address"/>
                    <TextBox x:Name="TxtEmail"
                             Height="35"
                             Padding="8"
                             Margin="0,4,0,8"/>

                    <TextBlock Text="role_name"/>
                    <TextBox x:Name="TxtRole"
                             Height="35"
                             Padding="8"
                             Margin="0,4,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="BtnAgregar"
                                Content="Agregar usuario"
                                Style="{StaticResource MenuButtonStyle}"
                                Width="160"
                                Margin="0,0,10,0"
                                Click="BtnAgregar_Click"/>

                        <Button x:Name="BtnConvertir"
                                Content="Convertir a ViewModels"
                                Style="{StaticResource MenuButtonStyle}"
                                Width="190"
                                Click="BtnConvertir_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <StackPanel>
                    <TextBlock Text="Resultado"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextoOscuro}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Datos API agregados:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <Border Background="{StaticResource FondoLavanda}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">

                        <TextBlock x:Name="TxtUsuariosApi"
                                   Text="Aún no hay usuarios agregados."
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="ViewModels generados:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <Border Background="{StaticResource FondoLavanda}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">

                        <TextBlock x:Name="TxtResultado"
                                   Text="Aún no se ha convertido ningún dato."
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="WPF → UsuarioApi → IUsuario → AdaptadorUsuario → UsuarioViewModel"
                               FontFamily="Consolas"
                               FontSize="13"
                               Foreground="{StaticResource TextoClaro}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>