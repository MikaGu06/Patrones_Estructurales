<UserControl x:Class="Patrones_Estructurales.Adapterr.Adapter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Patrones_Estructurales.Adapterr"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Botones superiores -->
        <UniformGrid Grid.Row="0"
                     Columns="3"
                     Margin="0,0,0,15">

            <Button x:Name="BtnLibreriaExterna"
                    Content="Librería externa"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Click="BtnLibreriaExterna_Click"/>

            <Button x:Name="BtnFormato"
                    Content="Formato JSON y XML"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Click="BtnFormato_Click"/>

            <Button x:Name="BtnViewModels"
                    Content="ViewModels"
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Click="BtnViewModels_Click"/>

        </UniformGrid>

        <!-- Aquí cambia el contenido -->
        <Border Grid.Row="1"
                CornerRadius="8"
                Padding="15">

            <ContentControl x:Name="ContenedorAdapter"/>

        </Border>

    </Grid>
</UserControl>